generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model Link {
  id  Int       @id @default(autoincrement())
  clerkId String
  name  String @unique
  url String @unique
  createdAt DateTime @default(now())

  @@unique([clerkId, url])
}